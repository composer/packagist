{% extends 'organization/layout.html.twig' %}

{% block title %}Remove team member - {{ organization.displayName }} - {{ parent() }}{% endblock %}

{% block org_content %}
    <h3 class="title">Remove "{{ member.username }}" from team "{{ team.name }}"</h3>

    <p>This removes the member from the team. This action cannot be undone.</p>

    {{ form_start(form, { 'attr': { 'class': 'organization_team_member_remove' } }) }}
        {{ form_errors(form) }}
        <input class="btn btn-danger" type="submit" value="Remove member" />
        <a class="btn btn-default" href="{{ path('organization_teams', { organization: organization.slug }) }}">Cancel</a>
    {{ form_end(form) }}
{% endblock %}
