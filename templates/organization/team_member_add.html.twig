{% extends 'organization/layout.html.twig' %}

{% block title %}Add member - {{ team.name }} - {{ organization.displayName }} - {{ parent() }}{% endblock %}

{% block org_content %}
    <h3 class="title">Add a member to "{{ team.name }}"</h3>

    {{ form_start(form, { 'attr': { 'class': 'organization_team_member_add' } }) }}
        {{ form_errors(form) }}
        <div class="form-group clearfix">
            {{ form_label(form.username) }}
            {{ form_errors(form.username) }}
            {{ form_widget(form.username) }}
            {{ form_help(form.username) }}
        </div>
        <input class="btn btn-success" type="submit" value="Add member" />
        <a class="btn btn-default" href="{{ path('organization_teams', { organization: organization.slug }) }}">Cancel</a>
    {{ form_end(form) }}
{% endblock %}
