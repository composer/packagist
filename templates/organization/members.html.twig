{% extends 'organization/layout.html.twig' %}

{% block title %}Members - {{ organization.displayName }} - {{ parent() }}{% endblock %}

{% set canRemove = is_granted(enum('App\\Security\\Voter\\OrganizationActions').RemoveMember.value, organization) %}

{% block org_content %}
    <h3 class="title">Members</h3>

    <table class="table">
        <thead>
            <tr>
                <th>Member</th>
                <th>Teams</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for member in members %}
                <tr>
                    <td>{{ member.user ? member.user.username : '(unknown user #' ~ member.userId ~ ')' }}</td>
                    <td>
                        {% for team in member.teams %}
                            <span class="label label-default">{{ team.name }}</span>
                        {% endfor %}
                    </td>
                    <td class="text-right">
                        {% if app.user and member.userId == app.user.id %}
                            <form method="post" action="{{ path('organization_member_leave', { organization: organization.slug }) }}"
                                  onsubmit="return confirm('Leave {{ organization.displayName|e('js') }}?');" style="display:inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('org_member_leave') }}">
                                <button type="submit" class="btn btn-xs btn-default">Leave</button>
                            </form>
                        {% elseif canRemove %}
                            <form method="post" action="{{ path('organization_member_remove', { organization: organization.slug, userId: member.userId }) }}"
                                  onsubmit="return confirm('Remove this member from the organization?');" style="display:inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('org_member_remove_' ~ member.userId) }}">
                                <button type="submit" class="btn btn-xs btn-danger">Remove</button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
