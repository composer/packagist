{# Shared modal used by the admin package-delete / version admin-delete / version-hide flows in js/view.js.
   Only rendered for admins; maintainers' non-admin deletes use a plain confirm() and never open it. #}
<div class="modal fade" id="deletion-reason-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"></h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Public reason <small class="text-muted">(optional — shown to everyone in the transparency log)</small></label>
                    <textarea class="form-control deletion-reason-public" rows="2"></textarea>
                </div>
                <div class="form-group">
                    <label>Internal reason <small class="text-muted">(optional — admin-only, <strong>not shown publicly</strong>, may contain private notes/PII)</small></label>
                    <textarea class="form-control deletion-reason-internal" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger deletion-reason-confirm"></button>
            </div>
        </div>
    </div>
</div>
