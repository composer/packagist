{% extends "layout.html.twig" %}

{% import "macros.html.twig" as macros %}

{% block head_additions %}
    {% if user.isFrozen() %}
        <meta name="robots" content="noindex, nofollow">
    {% endif %}
{% endblock %}

{% block content %}
{% set isActualUser = app.user and app.user.username is same as(user.username) %}
<h2 class="title">
    {{ user.username }}
    <small>
        {% if (is_granted('ROLE_ANTISPAM') or is_granted('ROLE_DISABLE_USERS')) and user.isFrozen() %}
            [FROZEN: {{ ('user_freeze_reasons.' ~ user.freezeReason.value)|trans }}]
        {% endif %}
        {{ 'user.member_since'|trans }}: {{ user.createdAt|date('M d, Y') }}
        &middot; <a rel="nofollow noindex" href="{{ path('view_transparency_log', {user: user.username}) }}">Transparency log</a>
        {%- if is_granted('ROLE_ADMIN') %}
            <a href="mailto:{{ user.email }}">{{ user.email }}</a>
        {%- endif %}
        {%- if deleteForm is defined and (is_granted('ROLE_ADMIN') or isActualUser) %}
            <form class="delete action" action="{{ path('user_delete', {name: user.username}) }}" method="POST">
                {{ form_widget(deleteForm._token) }}
                <input class="btn btn-danger" type="submit" value="Delete Account Permanently" onclick="return confirm('Are you sure? There is no way back..');" />
            </form>
        {%- endif %}
        {%- if freezeForm is defined %}
            {%- if user.isFrozen() %}
                {%- if canUnfreezeUser|default(false) %}
                    <button type="button" class="btn btn-success action" data-toggle="modal" data-target="#unfreeze-user-modal">Unfreeze account</button>
                {%- endif %}
            {%- else %}
                <button type="button" class="btn btn-danger action" data-toggle="modal" data-target="#freeze-user-modal">Freeze account</button>
            {%- endif %}
        {%- endif %}
    </small>
</h2>

{% if is_granted('ROLE_ADMIN') %}
    <div class="row" style="background-color: #f9f9f9; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
        <div class="col-md-6">
            <h4>User Metadata</h4>
            <dl class="dl-horizontal">
                <dt>Created At:</dt>
                <dd>{{ user.createdAt|date('Y-m-d H:i:s') }}</dd>

                <dt>Last Login:</dt>
                <dd>{{ user.lastLogin ? user.lastLogin|date('Y-m-d H:i:s') : 'Never' }}</dd>

                <dt>Pwd Reset Request:</dt>
                <dd>{{ user.passwordRequestedAt ? user.passwordRequestedAt|date('Y-m-d H:i:s') : 'N/A' }}</dd>

                <dt>GitHub:</dt>
                <dd>
                    {% if user.githubId %}
                        {{ user.githubId }}
                        {% if githubUsername is defined and githubUsername %}
                            - <a href="https://github.com/{{ githubUsername }}">{{ githubUsername }}</a>
                        {% endif %}
                    {% else %}
                        Not linked
                    {% endif %}
                </dd>

                {% if user.totpAuthenticationEnabled() %}
                    <dt>2FA:</dt>
                    <dd>Enabled - <a href="{{ path('user_2fa_configure', {name: user.username}) }}">Manage</a></dd>
                {% endif %}
            </dl>
        </div>

        <div class="col-md-6">
            <h4>Update Email Address</h4>
            <p class="help-block">Current email: {{ user.email }}</p>
            {{ form_start(adminEmailForm) }}
                <div class="form-group">
                    {{ form_widget(adminEmailForm.email, {'attr': {'class': 'form-control', 'placeholder': 'New email address'}}) }}
                </div>
                <button type="submit" class="btn btn-primary">Update Email</button>
            {{ form_end(adminEmailForm) }}
        </div>
    </div>
{% endif %}

<section class="row">
    <section class="col-md-12">
        {% embed "web/list.html.twig" with {noLayout: 'true', showAutoUpdateWarning: isActualUser} %}
            {% block content_title %}
                <h3 class="font-normal profile-title">{{ 'user.packages'|trans({ '%username%':user.username }) }}</h3>
            {% endblock %}
        {% endembed %}
    </section>
</section>

{% if freezeForm is defined %}
    {% if user.isFrozen() and canUnfreezeUser|default(false) %}
        <div class="modal fade" id="unfreeze-user-modal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog" role="document">
                {{ form_start(unfreezeForm, {'action': path('unfreeze_user', {name: user.username}), 'attr': {'class': 'modal-content'}}) }}
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        <h4 class="modal-title">Unfreeze {{ user.username }}</h4>
                    </div>
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Public reason <small class="text-muted">(optional — shown in the transparency log)</small></label>
                            {{ form_widget(unfreezeForm.reasonText, {'attr': {'class': 'form-control', 'rows': 2}}) }}
                        </div>
                        <div class="form-group">
                            <label>Internal reason <small class="text-muted">(optional — admin-only, <strong>not shown publicly</strong>, may contain private notes/PII)</small></label>
                            {{ form_widget(unfreezeForm.internalReason, {'attr': {'class': 'form-control', 'rows': 2}}) }}
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Unfreeze account</button>
                    </div>
                {{ form_end(unfreezeForm) }}
            </div>
        </div>
    {% else %}
        <div class="modal fade" id="freeze-user-modal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog" role="document">
                {{ form_start(freezeForm, {'action': path('freeze_user', {name: user.username}), 'attr': {'class': 'modal-content'}}) }}
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        <h4 class="modal-title">Freeze {{ user.username }}</h4>
                    </div>
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Reason</label>
                            {{ form_widget(freezeForm.reason, {'attr': {'class': 'form-control'}}) }}
                        </div>
                        <div class="form-group">
                            <label>Public reason <small class="text-muted">(optional — shown in the transparency log)</small></label>
                            {{ form_widget(freezeForm.reasonText, {'attr': {'class': 'form-control', 'rows': 2}}) }}
                        </div>
                        <div class="form-group">
                            <label>Internal reason <small class="text-muted">(optional — admin-only, <strong>not shown publicly</strong>, may contain private notes/PII)</small></label>
                            {{ form_widget(freezeForm.internalReason, {'attr': {'class': 'form-control', 'rows': 2}}) }}
                        </div>
                        {% if freezeForm.freezePackages is defined %}
                            <hr>
                            <div class="checkbox">
                                <label>{{ form_widget(freezeForm.freezePackages) }} Also act on the user's packages</label>
                            </div>
                            <div class="form-group">
                                <label>Package freeze reason</label>
                                {{ form_widget(freezeForm.packageFreezeReason, {'attr': {'class': 'form-control'}}) }}
                            </div>
                            <div class="checkbox">
                                <label>{{ form_widget(freezeForm.purgePackages) }} Purge package metadata <small class="text-muted">(soft-delete all versions and remove all published metadata; ignored for temporary freezes)</small></label>
                            </div>
                        {% endif %}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Freeze account</button>
                    </div>
                {{ form_end(freezeForm) }}
            </div>
        </div>
    {% endif %}
{% endif %}
{% endblock %}
