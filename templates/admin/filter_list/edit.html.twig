{% extends "admin/layout.html.twig" %}

{% block title %}Edit filter list entry - {{ parent() }}{% endblock %}

{% block admin_content %}
    <div class="row">
        <div class="col-xs-12 package">
            <div class="package-header">
                <h2 class="title">
                    Edit filter list entry
                    <small>{{ entry.publicId }}</small>
                </h2>
                {% if entry.manual %}
                    <p>
                        This entry was added manually. Its properties can be edited,
                        except the package name which is fixed once the entry is created.
                    </p>
                {% else %}
                    <p>
                        Editing the version constraint stores it as an admin overwrite; the
                        upstream-reported version is preserved separately so the next sync
                        from the provider will not recreate the original entry.
                    </p>
                    {% if entry.overwritten %}
                        <div class="alert alert-info">
                            Upstream version: <code>{{ entry.remoteVersion }}</code>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            {{ form_start(form) }}
            {{ form_errors(form) }}

            {{ form_row(form.list) }}
            {{ form_row(form.source) }}
            {{ form_row(form.packageName) }}
            {{ form_row(form.version) }}
            {{ form_row(form.reason) }}
            {{ form_row(form.link) }}
            {{ form_row(form.internalNote) }}

            <button type="submit" class="btn btn-success">Save</button>
            <a class="btn btn-default" href="{{ path('admin_filter_lists') }}">Cancel</a>

            {{ form_end(form) }}
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <hr/>
            <h3>Logs</h3>
            {% include 'audit_log/_transparency_log_table.html.twig' with {
                displays: auditLogDisplays,
                emptyMessage: 'No transparency log entries for this filter list entry yet.',
            } only %}
        </div>
    </div>
{% endblock %}
